  "summary": {
    "totalRoutes": 49,
    "routesByModule": {
      "app": 4,
      "auth": 4,
      "patients": 5,
      "therapists": 5,
      "sessions": 3,
      "tests": 4,
      "consultations": 5,
      "objectives": 5,
      "reports": 5,
      "scenarios": 5
    },
    "authentication": {
      "type": "JWT Bearer Token",
      "location": "Authorization header",
      "publicRoutes": [
        "GET /",
        "GET /health",
        "GET /api-docs",
        "GET /api-docs.json",
        "POST /auth/register",
        "POST /auth/login",
        "POST /auth/forgot-password",
        "POST /auth/reset-password",
        "POST /sessions/attach"
      ]
    },
    "rateLimiting": {
      "global": "300 requests per 15 minutes",
      "sessions": {
        "validate": "50 requests per 10 minutes",
        "attach": "30 requests per 10 minutes"
      }
    },
    "userRoles": [
      "PATIENT - Can access own data, view therapist info, take tests",
      "THERAPIST - Can access patient data, create/update records, manage scenarios and objectives",
      "ADMIN - Can access all data and perform all operations"
    ]
  }
}
