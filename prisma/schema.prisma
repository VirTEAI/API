generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PATIENT
  THERAPIST
  ADMIN
}

enum AttendanceModality {
  ONLINE
  PRESENTIAL
  BOTH
}

enum CareStatus {
  NOT_STARTED
  IN_PROGRESS
  PAUSED
  FINISHED
}

enum ProgressStatus {
  MAINTAINED
  IMPROVED
  REGRESSED
}

enum ScenarioStatus {
  NOT_STARTED
  IN_PROGRESS
  FINISHED
}

// enum NotificationStatus {
  // UNREAD
  // READ
  // ARCHIVED
// }

// enum NotificationType {
  // SYSTEM
  // APPOINTMENT
  // REMINDER
  // REPORT
  // OTHER
// }

model User {
  userId           Int        @id @default(autoincrement())
  email            String     @unique
  name             String
  password         String
  role             UserRole   @default(PATIENT)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?
  sessionIdHash    String?    @unique
  sessionIdExpiry  DateTime?

  patientProfile   PatientProfile?
  therapistProfile TherapistProfile?
  sessions         SessionData[]
  // notifications    Notification[]
}

model PatientProfile {
  patientProfileId Int           @id @default(autoincrement())
  userId           Int           @unique
  country          String
  city             String
  birthDate        DateTime
  careStatus       CareStatus    @default(NOT_STARTED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User                  @relation(fields: [userId], references: [userId])
  therapeuticObjectives TherapeuticObjective[]
  scenarios        Scenario[]
  reports          Report[]
  consultations    Consultation[] @relation("PatientConsultations")
}

model TherapistProfile {
  therapistProfileId    Int                @id @default(autoincrement())
  userId                Int                @unique
  professionalRegister String
  country              String
  city                 String
  birthDate            DateTime
  position             String
  specialty            String
  experience           String
  attendanceModality   AttendanceModality  @default(ONLINE)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user                  User                  @relation(fields: [userId], references: [userId])
  therapeuticObjectives TherapeuticObjective[]
  scenarios             Scenario[]
  reports               Report[]
  consultations         Consultation[] @relation("TherapistConsultations")
}

model TherapeuticObjective {
  therapeuticObjectiveId Int             @id @default(autoincrement())
  patientProfileId       Int
  therapistProfileId     Int
  title                  String
  evolution              ProgressStatus   @default(MAINTAINED)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  patient                PatientProfile   @relation(fields: [patientProfileId], references: [patientProfileId])
  therapist              TherapistProfile @relation(fields: [therapistProfileId], references: [therapistProfileId])

  @@index([patientProfileId])
  @@index([therapistProfileId])
}

model Scenario {
  scenarioId         Int             @id @default(autoincrement())
  patientProfileId   Int
  therapistProfileId Int
  title              String
  status             ScenarioStatus   @default(NOT_STARTED)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  patient            PatientProfile   @relation(fields: [patientProfileId], references: [patientProfileId])
  therapist          TherapistProfile @relation(fields: [therapistProfileId], references: [therapistProfileId])

  @@index([patientProfileId])
  @@index([therapistProfileId])
}

model Consultation {
  consultationId     Int              @id @default(autoincrement())
  patientProfileId   Int
  therapistProfileId Int
  consultationDate   DateTime
  objective          String
  score              Int
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  patient            PatientProfile    @relation("PatientConsultations", fields: [patientProfileId], references: [patientProfileId])
  therapist          TherapistProfile  @relation("TherapistConsultations", fields: [therapistProfileId], references: [therapistProfileId])
  report             Report?

  @@index([patientProfileId])
  @@index([therapistProfileId])
  @@index([consultationDate])
}

model Report {
  reportId           Int              @id @default(autoincrement())
  patientProfileId   Int
  therapistProfileId Int
  consultationId     Int?             @unique
  sessionObjective   String
  title              String
  evolution          ProgressStatus
  content            String
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  patient            PatientProfile   @relation(fields: [patientProfileId], references: [patientProfileId])
  therapist          TherapistProfile @relation(fields: [therapistProfileId], references: [therapistProfileId])
  consultation       Consultation?    @relation(fields: [consultationId], references: [consultationId])

  @@index([patientProfileId])
  @@index([therapistProfileId])
}

